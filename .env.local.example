# ─── Agent Studio API ──────────────────────────────────────────────────────────
# URL of the backend API (services/api Express dev server or Lambda via API Gateway)
# Leave blank to use mock data (no API calls will be made)
VITE_AGENT_API_URL=http://localhost:3001

# Company ID to use for all API calls and meeting sessions
VITE_COMPANY_ID=dev-company

