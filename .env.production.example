# Copy to .env.production and fill in real values after running:
#   npm run provision

# API Gateway invoke URL printed by provision-aws.ts
VITE_API_URL=https://<api-id>.execute-api.us-east-2.amazonaws.com

# Optional: separate read-only agent API (agentApi.ts)
# VITE_AGENT_API_URL=https://<api-id>.execute-api.us-east-2.amazonaws.com
