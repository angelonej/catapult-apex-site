{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "vite preview",
    "local-api": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/dynamodb/local-api.ts",
    "seed": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/dynamodb/seed-agents.ts",
    "seed:all": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/dynamodb/seed-all.ts",
    "seed-board": "tsx infra/dynamodb/seed-board.ts",
    "export-data": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/lambda/export-local-data.ts",
    "provision": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/lambda/provision-aws.ts",
    "push-setup": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/lambda/push-setup.ts",
    "push-prod": "tsx --tsconfig infra/dynamodb/tsconfig.json infra/lambda/push-prod-setup.ts",
    "check": "node scripts/mp-sync-check.mjs",
    "check:dry": "node scripts/mp-sync-check.mjs --dry",
    "hooks:install": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@aws-sdk/client-apigatewayv2": "^3.1003.0",
    "@aws-sdk/client-dynamodb": "^3.1002.0",
    "@aws-sdk/client-iam": "^3.1003.0",
    "@aws-sdk/client-lambda": "^3.1003.0",
    "@aws-sdk/client-sts": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.1002.0",
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
}
